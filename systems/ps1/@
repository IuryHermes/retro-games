<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PS1 | NeoTerminal</title>
    <style>
        html, body { margin: 0; background: #000; width: 100%; height: 100%; overflow: hidden; }
        #game { width: 100%; height: 100%; }
    </style>
</head>
<body>
    <div id="game"></div>
    <script>
        const params = new URLSearchParams(window.location.search);
        var rom = params.get("game");

        if (rom) {
            const baseUrl = window.location.origin + '/systems/ps1/';
            
            window.EJS_player = '#game';
            window.EJS_core = 'psx';
            window.EJS_pathtodata = 'https://cdn.emulatorjs.org/stable/data/';
            
            // Aqui está o segredo: enviamos a URL completa para o emulador não se perder
            window.EJS_gameUrl = rom.startsWith('http') ? rom : baseUrl + rom;
            window.EJS_biosUrl = baseUrl + 'roms/scph5501.bin';
            
            window.EJS_startOnLoaded = true;
            window.EJS_language = "pt-BR";
            window.EJS_AdUrl = ""; // Remove anúncios do emulador
            
        } else {
            alert("Erro: Jogo não encontrado.");
        }
    </script>
    <script src="https://cdn.emulatorjs.org/stable/data/loader.js"></script>
</body>
</html>
